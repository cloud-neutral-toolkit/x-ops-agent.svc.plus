PG_URL=postgres://postgres:postgres@127.0.0.1:5432/ops?sslmode=disable
LISTEN_ADDR=:8080

GITHUB_TOKEN=ghp_xxx
GITHUB_OWNER=your-github-user-or-org
GITHUB_REPO=your-gitops-repo
GITHUB_BASE_BRANCH=main
GITHUB_FILE_PATH=charts/app/values.yaml
FLAG_PATH=featureFlags.recommendation_v2

# Optional ArgoCD
ARGOCD_URL=
ARGOCD_TOKEN=
ARGOCD_APP=

# OPS agent + MCP server
OPS_HTTP_ADDR=:18080
OPS_MCP_SERVER_NAME=xops-mcp
OPS_WORKING_DIR=.
OPS_CODEX_ENABLED=true
OPS_CODEX_COMMAND=codex
OPS_CODEX_MODEL=gpt-5.2-codex
OPS_CODEX_SANDBOX=read-only
CODEX_REPO_DIR=./third_party/codex

# OpenClaw gateway as intelligent agent
OPENCLAW_COMMAND=openclaw
OPENCLAW_GATEWAY_URL=wss://openclaw.example/ws
OPENCLAW_GATEWAY_TOKEN=replace-me
OPENCLAW_GATEWAY_PASSWORD=
OPENCLAW_AGENT_ID=xops-agent
OPENCLAW_AGENT_NAME=XOpsAgent
OPENCLAW_AGENT_WORKSPACE=.
OPENCLAW_AGENT_MODEL=gpt-5.2-codex
OPENCLAW_GATEWAY_TIMEOUT_SECONDS=90
OPENCLAW_REGISTER_ON_START=false

# Optional OpenAI-compatible AI gateway for Codex fallback
AI_GATEWAY_URL=https://api.example.com/v1
AI_GATEWAY_API_KEY=replace-me
